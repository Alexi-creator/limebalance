generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model Plan {
  id                      String    @id @default(uuid())
  name                    String    @unique
  // Combined usage caps (mainly for the free tier). NULL = unlimited (pro / ultra).
  maxCategories           Int? // total expense + income categories (lifetime)
  maxTransactionsPerMonth Int? // expenses + incomes within the current calendar month
  price                   Decimal   @db.Decimal(10, 2)
  // Feature gate: unlocks the investing / crypto section. The differentiator between free and paid plans.
  investingAccess         Boolean   @default(false)
  // Soft retirement. NULL = active (offered for new subscriptions); a timestamp = archived. Archived
  // plans are hidden from new signups, but existing subscribers keep the plan and its functionality
  // until their subscription expires. Lets a paid plan be pulled from sale without stripping paid time.
  archivedAt              DateTime? @map("archived_at")

  subscriptions UserSubscription[]

  @@map("plans")
}

model UserSubscription {
  id        String    @id @default(uuid())
  userId    String    @unique @map("user_id")
  planId    String    @map("plan_id")
  expiresAt DateTime?
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@map("user_subscriptions")
}

model User {
  id               String    @id @default(uuid())
  telegramId       BigInt?   @unique @map("telegram_id")
  // Telegram @username — display-only (admin panel). Nullable: not every account has one.
  // Refreshed on every bot interaction and Telegram login, since users can change it.
  telegramUsername String?   @map("telegram_username")
  // Telegram `language_code` (e.g. "ru", "en-US") — refreshed on every bot interaction, same as
  // telegramUsername. Used to pick the language for proactive pushes (digest, trade-closed),
  // which have no live update to read a language_code from. NULL until the user's first bot
  // interaction after this field was introduced — resolveLocale() defaults that to Russian.
  languageCode     String?   @map("language_code")
  googleId         String?   @unique @map("google_id")
  email            String?   @unique
  // Whether the email on this account has been confirmed. true for Google (Google verifies it)
  // and for emails confirmed via the link; false for fresh email/password registrations until the
  // user follows the confirmation link. Accounts with no email keep the default and are ignored.
  emailVerified    Boolean   @default(false) @map("email_verified")
  password         String?
  name             String    @default("")
  role             Role      @default(USER)
  currency         String    @default("USD")
  timezone         String    @default("UTC")
  // Admin block. NULL = active; a timestamp = blocked (and when). Blocked users are rejected at the
  // JWT layer, so they can't make any authenticated request.
  blockedAt        DateTime? @map("blocked_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  expenseCategories          ExpenseCategory[]
  expenses                   Expense[]
  incomeCategories           IncomeCategory[]
  incomes                    Income[]
  state                      UserState?
  refreshTokens              RefreshToken[]
  passwordResetTokens        PasswordResetToken[]
  emailVerificationTokens    EmailVerificationToken[]
  subscription               UserSubscription?
  notifications              Notification[]
  goals                      Goal[]
  goalContributions          GoalContribution[]
  exchangeAccounts           ExchangeAccount[]
  tradeExecutions            TradeExecution[]
  positions                  Position[]
  positionNotes              PositionNote[]
  holdings                   Holding[]
  botNotificationPreferences BotNotificationPreference[]

  @@map("users")
}

model Goal {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  name         String
  emoji        String?
  targetAmount Decimal   @map("target_amount") @db.Decimal(12, 2)
  currency     String
  // Month/year deadline (stored as a date). NULL = no deadline ("До 2028" granularity is on the UI).
  targetDate   DateTime? @map("target_date") @db.Date
  // Manual "в архив". Archived goals stop reserving money from the free balance.
  archived     Boolean   @default(false)
  // Set once when the goal first reaches its target (drives the "Цель достигнута" notification).
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions GoalContribution[]

  @@index([userId, archived])
  @@map("goals")
}

model GoalContribution {
  id        String   @id @default(uuid())
  goalId    String   @map("goal_id")
  userId    String   @map("user_id")
  // In the goal's currency. May be negative — a withdrawal / correction.
  amount    Decimal  @db.Decimal(12, 2)
  note      String?
  date      DateTime @db.Date
  createdAt DateTime @default(now()) @map("created_at")

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([goalId, date])
  @@index([userId])
  @@map("goal_contributions")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String
  // Stable key for derived notifications (e.g. "monthly_summary:2026-06") so re-generation
  // upserts the same row instead of duplicating. NULL for one-off items like news.
  dedupeKey String?   @map("dedupe_key")
  // Optional server-rendered fallback text. Templated notifications (monthly_summary, goal_completed)
  // are localized by the frontend from `payload`; free-form items (e.g. news) may still carry text here.
  title     String?
  body      String?
  // Structured data behind the notification (amounts, category, period…). Source of truth for the
  // frontend to render/localize. title/body are only a fallback.
  payload   Json?
  isRead    Boolean   @default(false) @map("is_read")
  createdAt DateTime  @default(now()) @map("created_at")
  readAt    DateTime? @map("read_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

// Per-user opt-out for a proactive Telegram bot push (e.g. "monthly_digest", "trade_closed").
// Absence of a row means enabled — so a new notification type introduced later is on by default
// for everyone without a backfill migration; a row only exists once a user actually flips it.
model BotNotificationPreference {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("bot_notification_preferences")
}

model ExpenseCategory {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  emoji     String?
  createdAt DateTime @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@index([userId])
  @@map("expense_categories")
}

model Expense {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  categoryId  String   @map("category_id")
  amount      Decimal  @db.Decimal(12, 2)
  currency    String
  amountUsd   Decimal? @map("amount_usd") @db.Decimal(14, 2)
  description String
  date        DateTime @db.Date
  createdAt   DateTime @default(now()) @map("created_at")

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([userId, date, createdAt])
  @@index([categoryId])
  @@map("expenses")
}

model IncomeCategory {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  emoji     String?
  createdAt DateTime @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomes Income[]

  @@index([userId])
  @@map("income_categories")
}

model Income {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  categoryId  String   @map("category_id")
  amount      Decimal  @db.Decimal(12, 2)
  currency    String
  amountUsd   Decimal? @map("amount_usd") @db.Decimal(14, 2)
  description String
  date        DateTime @db.Date
  createdAt   DateTime @default(now()) @map("created_at")

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  category IncomeCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([userId, date, createdAt])
  @@index([categoryId])
  @@map("incomes")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// Email confirmation, used by two flows:
//  - Telegram-link: the user adds an email to a Telegram-created account. Until the link is
//    followed, the email and password live here (not on the user). password is set.
//  - Registration: the email/password are already on the user; this token only confirms ownership
//    and flips users.email_verified. password is NULL.
model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  email     String
  // Pending password for the Telegram-link flow (email not yet on the account). NULL for the
  // registration flow, where the email/password already live on the user and the token only
  // confirms ownership (flips users.email_verified).
  password  String?
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

enum ExchangeAccountStatus {
  ACTIVE
  ERROR // last sync failed (bad key, network…) — kept retrying, lastError is shown in the UI
  DISABLED // paused by the user; the cron skips it
}

// A connected exchange API key (investing / crypto diary section).
model ExchangeAccount {
  id                 String                @id @default(uuid())
  userId             String                @map("user_id")
  // Exchange slug; only "bybit" for now, but the sync/UI are keyed by it for future exchanges.
  exchange           String                @default("bybit")
  label              String                @default("")
  // AES-256-GCM, "iv:tag:ciphertext" base64 (see investing/crypto.util.ts). Never returned by the API.
  apiKey             String                @map("api_key")
  apiSecret          String                @map("api_secret")
  status             ExchangeAccountStatus @default(ACTIVE)
  lastError          String?               @map("last_error")
  // History is pulled starting from this point — set to the user's registration date on connect,
  // so crypto history begins together with the rest of the app's money history.
  syncFrom           DateTime              @map("sync_from")
  // Sync cursors: records up to these timestamps are already in the DB (advance monotonically).
  closedPnlSyncedTo  DateTime?             @map("closed_pnl_synced_to")
  executionsSyncedTo DateTime?             @map("executions_synced_to")
  lastSyncAt         DateTime?             @map("last_sync_at")
  createdAt          DateTime              @default(now()) @map("created_at")

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  executions TradeExecution[]
  positions  Position[]

  @@index([userId])
  @@index([status])
  @@map("exchange_accounts")
}

// A single fill (partial execution of an order), as reported by the exchange. Raw material for
// the diary details; closed positions are the aggregated view the user works with.
model TradeExecution {
  id          String   @id @default(uuid())
  accountId   String   @map("account_id")
  userId      String   @map("user_id")
  execId      String   @map("exec_id")
  orderId     String   @map("order_id")
  symbol      String
  // Bybit product category: linear (USDT perp) for the MVP; spot/inverse later.
  category    String
  side        String // Buy | Sell
  // Bybit execType: "Trade" for real fills, "Funding" for funding-fee settlements
  // (also AdlTrade/BustTrade/Delivery — treated as trades, only Funding is singled out).
  execType    String   @default("Trade") @map("exec_type")
  price       Decimal  @db.Decimal(30, 12)
  qty         Decimal  @db.Decimal(30, 12)
  fee         Decimal  @db.Decimal(30, 12)
  feeCurrency String?  @map("fee_currency")
  execTime    DateTime @map("exec_time")
  // Original exchange payload — lets us backfill new columns without re-fetching.
  raw         Json?
  createdAt   DateTime @default(now()) @map("created_at")

  account ExchangeAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The exchange's execId is the idempotency key: re-syncing the same window upserts, never duplicates.
  @@unique([accountId, execId])
  @@index([userId, execTime])
  @@index([accountId, symbol, execTime])
  @@map("trade_executions")
}

enum PositionStatus {
  OPEN
  CLOSED
}

// A trade in the diary, open or closed. Comes either from an exchange sync (source=bybit,
// core trade fields immutable via the API) or entered by hand (source=manual, full CRUD).
// Synced positions are created OPEN (from Bybit's live position list) and the same row is
// updated in place when Bybit later reports it closed — never a separate row per state.
// Journal notes (entry reason, updates, exit reason, screenshots) live on PositionNote and can
// be added regardless of source or status — that's the part meant to survive the whole trade.
model Position {
  id            String         @id @default(uuid())
  // NULL for manual entries — they don't belong to any exchange account.
  accountId     String?        @map("account_id")
  userId        String         @map("user_id")
  source        String         @default("bybit") // bybit | manual
  status        PositionStatus @default(CLOSED)
  // Bybit id of the closing order — the dedupe key for closed-pnl records. NULL while open and
  // for manual entries.
  orderId       String?        @map("order_id")
  symbol        String
  category      String
  // Side of the CLOSING order: Sell closes a long, Buy closes a short (manual entries and open
  // positions are stored with the same convention so all rows read uniformly).
  side          String
  qty           Decimal        @db.Decimal(30, 12)
  avgEntryPrice Decimal        @map("avg_entry_price") @db.Decimal(30, 12)
  // NULL while the position is open.
  avgExitPrice  Decimal?       @map("avg_exit_price") @db.Decimal(30, 12)
  // Realized PnL in the settlement currency (USDT for linear), fees included by Bybit. NULL
  // while open.
  closedPnl     Decimal?       @map("closed_pnl") @db.Decimal(30, 12)
  leverage      Decimal?       @db.Decimal(10, 2)
  // Bybit's closed-pnl records carry no open time. Spot is derived by FIFO over the fills
  // (spot-fifo.util), linear by matching closing qty against opening fills (linear-fifo.util) —
  // NULL there only when the opening fills predate the synced history. Manual entries may set it.
  // Synced OPEN positions get it straight from Bybit's position list (createdTime).
  openedAt      DateTime?      @map("opened_at")
  // NULL while open.
  closedAt      DateTime?      @map("closed_at")
  raw           Json?
  createdAt     DateTime       @default(now()) @map("created_at")

  account ExchangeAccount? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes   PositionNote[]

  @@unique([accountId, orderId])
  @@index([userId, closedAt])
  @@index([accountId, symbol, closedAt])
  @@index([accountId, symbol, category, status])
  @@map("positions")
}

// A free-form journal entry attached to a position — entry reason, a later update, the exit
// reason, a screenshot. Independent of the position's source/status: notes can be added to a
// synced trade just as freely as a manual one, and to an open position just as a closed one.
model PositionNote {
  id         String   @id @default(uuid())
  positionId String   @map("position_id")
  userId     String   @map("user_id")
  body       String
  // External image URL (chart screenshot, etc.) — no upload/storage of our own, just a link.
  imageUrl   String?  @map("image_url")
  createdAt  DateTime @default(now()) @map("created_at")

  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([positionId, createdAt])
  @@map("position_notes")
}

// A manually tracked asset holding ("0.5 BTC in a cold wallet") — the portfolio view, independent
// of exchange sync. Valued at current market prices on read.
model Holding {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  // Asset ticker: BTC, ETH, SOL, USDT…
  asset       String
  amount      Decimal  @db.Decimal(30, 12)
  // Average acquisition price per unit in USD. NULL = unknown (gift, mining) — then no PnL is shown.
  avgBuyPrice Decimal? @map("avg_buy_price") @db.Decimal(30, 12)
  // Free-form: exchange name, cold wallet, staking…
  location    String   @default("")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("holdings")
}

model UserState {
  userId       String   @id @map("user_id")
  step         String
  categoryId   String?  @map("category_id")
  categoryName String?  @map("category_name")
  amount       Decimal? @db.Decimal(12, 2)
  description  String?
  isDetails    Boolean  @default(false) @map("is_details")
  period       String   @default("")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_states")
}
