generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model Plan {
  id   String @id @default(uuid())
  name String @unique
  // Combined usage caps (mainly for the free tier). NULL = unlimited (pro / ultra).
  maxCategories         Int? // total expense + income categories (lifetime)
  maxTransactionsPerMonth Int? // expenses + incomes within the current calendar month
  price                 Decimal @db.Decimal(10, 2)
  // Feature gate: unlocks the investing / crypto section. The differentiator between free and paid plans.
  investingAccess Boolean @default(false)

  subscriptions UserSubscription[]

  @@map("plans")
}

model UserSubscription {
  id        String    @id @default(uuid())
  userId    String    @unique @map("user_id")
  planId    String    @map("plan_id")
  expiresAt DateTime?
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@map("user_subscriptions")
}

model User {
  id         String   @id @default(uuid())
  telegramId BigInt?  @unique @map("telegram_id")
  googleId   String?  @unique @map("google_id")
  email      String?  @unique
  // Whether the email on this account has been confirmed. true for Google (Google verifies it)
  // and for emails confirmed via the link; false for fresh email/password registrations until the
  // user follows the confirmation link. Accounts with no email keep the default and are ignored.
  emailVerified Boolean @default(false) @map("email_verified")
  password   String?
  name       String   @default("")
  role       Role     @default(USER)
  currency   String   @default("USD")
  timezone   String   @default("UTC")
  // Admin block. NULL = active; a timestamp = blocked (and when). Blocked users are rejected at the
  // JWT layer, so they can't make any authenticated request.
  blockedAt  DateTime? @map("blocked_at")
  createdAt  DateTime @default(now()) @map("created_at")

  expenseCategories       ExpenseCategory[]
  expenses                Expense[]
  incomeCategories        IncomeCategory[]
  incomes                 Income[]
  state                   UserState?
  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  subscription            UserSubscription?
  notifications           Notification[]
  goals                   Goal[]
  goalContributions       GoalContribution[]

  @@map("users")
}

model Goal {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  name         String
  emoji        String?
  targetAmount Decimal   @map("target_amount") @db.Decimal(12, 2)
  currency     String
  // Month/year deadline (stored as a date). NULL = no deadline ("До 2028" granularity is on the UI).
  targetDate   DateTime? @map("target_date") @db.Date
  // Manual "в архив". Archived goals stop reserving money from the free balance.
  archived     Boolean   @default(false)
  // Set once when the goal first reaches its target (drives the "Цель достигнута" notification).
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions GoalContribution[]

  @@index([userId, archived])
  @@map("goals")
}

model GoalContribution {
  id        String   @id @default(uuid())
  goalId    String   @map("goal_id")
  userId    String   @map("user_id")
  // In the goal's currency. May be negative — a withdrawal / correction.
  amount    Decimal  @db.Decimal(12, 2)
  note      String?
  date      DateTime @db.Date
  createdAt DateTime @default(now()) @map("created_at")

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([goalId, date])
  @@index([userId])
  @@map("goal_contributions")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String
  // Stable key for derived notifications (e.g. "monthly_summary:2026-06") so re-generation
  // upserts the same row instead of duplicating. NULL for one-off items like news.
  dedupeKey String?   @map("dedupe_key")
  // Optional server-rendered fallback text. Templated notifications (monthly_summary, goal_completed)
  // are localized by the frontend from `payload`; free-form items (e.g. news) may still carry text here.
  title     String?
  body      String?
  // Structured data behind the notification (amounts, category, period…). Source of truth for the
  // frontend to render/localize. title/body are only a fallback.
  payload   Json?
  isRead    Boolean   @default(false) @map("is_read")
  createdAt DateTime  @default(now()) @map("created_at")
  readAt    DateTime? @map("read_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model ExpenseCategory {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  emoji     String?
  createdAt DateTime @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@index([userId])
  @@map("expense_categories")
}

model Expense {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  categoryId  String   @map("category_id")
  amount      Decimal  @db.Decimal(12, 2)
  currency    String
  amountUsd   Decimal? @map("amount_usd") @db.Decimal(14, 2)
  description String
  date        DateTime @db.Date
  createdAt   DateTime @default(now()) @map("created_at")

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([userId, date, createdAt])
  @@index([categoryId])
  @@map("expenses")
}

model IncomeCategory {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  emoji     String?
  createdAt DateTime @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomes Income[]

  @@index([userId])
  @@map("income_categories")
}

model Income {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  categoryId  String   @map("category_id")
  amount      Decimal  @db.Decimal(12, 2)
  currency    String
  amountUsd   Decimal? @map("amount_usd") @db.Decimal(14, 2)
  description String
  date        DateTime @db.Date
  createdAt   DateTime @default(now()) @map("created_at")

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  category IncomeCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([userId, date, createdAt])
  @@index([categoryId])
  @@map("incomes")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// Email confirmation, used by two flows:
//  - Telegram-link: the user adds an email to a Telegram-created account. Until the link is
//    followed, the email and password live here (not on the user). password is set.
//  - Registration: the email/password are already on the user; this token only confirms ownership
//    and flips users.email_verified. password is NULL.
model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  email     String
  // Pending password for the Telegram-link flow (email not yet on the account). NULL for the
  // registration flow, where the email/password already live on the user and the token only
  // confirms ownership (flips users.email_verified).
  password  String?
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model UserState {
  userId       String   @id @map("user_id")
  step         String
  categoryId   String?  @map("category_id")
  categoryName String?  @map("category_name")
  amount       Decimal? @db.Decimal(12, 2)
  description  String?
  isDetails    Boolean  @default(false) @map("is_details")
  period       String   @default("")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_states")
}
